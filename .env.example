# ─── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_your_api_key

# ─── Application ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_ENV=development
INTERNAL_API_SECRET=your-internal-secret

# ─── Server ──────────────────────────────────────────────
PORT=8080

# ─── Clerk Auth ───────────────────────────────────────────
# Clerk credentials for session verification
# Get from: Clerk Dashboard → API Keys → Copy Secret Key + Publishable Key
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# ─── Supabase Auth Hook ──────────────────────────────────
# Supabase Auth Hook signing secret
# Get from: Supabase Dashboard → Authentication → Hooks → Send Email
SUPABASE_HOOK_SECRET=

# Your deployed site base URL, no trailing slash
SITE_URL=https://comfhutt.com

# ─── CRUX ────────────────────────────────────────────────
GEMINI_API_KEY=               # Google AI Studio → ai.google.dev → Get API key
GOOGLE_MAPS_API_KEY=          # Google Cloud Console → APIs → Maps + Geocoding
CRUX_VERSION=0.1.0            # Scoring engine version — stamped on every score

# CRUX Data Source Configuration
CPCB_API_URL=https://app.cpcbccr.com/caaqms/caaqms_viewData_v2
MCA21_SEARCH_URL=https://www.mca.gov.in/mcafoportal/companyLLPMasterData.do
ECOURTS_API_URL=https://webapi.ecourtsindia.com/api/partner
ECOURTS_API_KEY=eci_live_your_token_here
